local function C_8()
local script = G2L["8"];
	local textLabel = script.Parent
	local StarterGui = game:GetService("StarterGui")
	
	------------------------------------------------
	-- FIND TOP UI CONTAINER
	------------------------------------------------
	local function getTopParent(obj)
		local current = obj
		while current.Parent do
			if current:IsA("ScreenGui") then
				return current
			end
			current = current.Parent
		end
		return obj
	end
	
	local topUI = getTopParent(textLabel)
	
	------------------------------------------------
	-- NOTIFICATION FUNCTION
	------------------------------------------------
	local function notif()
		StarterGui:SetCore("SendNotification", {
			Title = "Internal Installer",
			Text = "Installer has been closed, all installation packages have been removed",
			Button1 = "Okay",
			Duration = 3
		})
	end
	
	------------------------------------------------
	-- ENABLE CLICK
	------------------------------------------------
	textLabel.Active = true
	
	textLabel.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
	
			-- show notification first
			notif()
	
			-- small delay so notification appears
			task.wait(0.1)
	
			-- destroy full UI hierarchy
			if topUI then
				topUI:Destroy()
			end
		end
	end)
end;
