local function C_f()
local script = G2L["f"];
	local bar = script.Parent
	local random = Random.new()
	
	local function parseUDim2(str)
		local xScale, xOffset, yScale, yOffset = str:match("{(.-),%s*(.-)},{(.-),%s*(.-)}")
		return UDim2.new(
			tonumber(xScale) or 0,
			tonumber(xOffset) or 0,
			tonumber(yScale) or 0,
			tonumber(yOffset) or 0
		)
	end
	
	local function lerp(a, b, t)
		return a + (b - a) * t
	end
	
	local function lerpUDim2(from, to, t)
		return UDim2.new(
			lerp(from.X.Scale, to.X.Scale, t),
			lerp(from.X.Offset, to.X.Offset, t),
			lerp(from.Y.Scale, to.Y.Scale, t),
			lerp(from.Y.Offset, to.Y.Offset, t)
		)
	end
	
	local emptySize = parseUDim2(bar:WaitForChild("EmptySize").Value)
	local fullSize = parseUDim2(bar:WaitForChild("FullSize").Value)
	
	bar.Size = emptySize
	
	local totalSteps = 1000
	
	local segments = {
		{0.35, 30, 0.05, 0.2, 1.5},
		{0.50, 13, 0.05, 0.2, 2},
		{0.75, 21, 0.05, 0.2, 1},
		{1,    21, 0.05, 0.2, 0},
	}
	
	local currentProgress = 0
	
	for _, seg in ipairs(segments) do
		local target = seg[1]
		local segmentProgress = target - currentProgress
	
		for i = 1, seg[2] do
			local step = currentProgress + segmentProgress * (i / seg[2])
			bar.Size = lerpUDim2(emptySize, fullSize, step)
			task.wait(random:NextNumber(seg[3], seg[4]))
		end
	
		currentProgress = target
	
		if seg[5] > 0 then
			task.wait(seg[5])
		end
	end
end;
