local function C_4()
local script = G2L["4"];
	local player = game:GetService("Players").LocalPlayer
	local HttpService = game:GetService("HttpService")
	local userId = tostring(player.UserId)
	
	local BLOB_ID = "019e32a8-7e8d-71cc-bb7f-b60d13760df7"
	local BASE_URL = "https://jsonblob.com/api/jsonBlob"
	
	local function saveData(isOldUser)
		local success, err = pcall(function()
			local current = HttpService:GetAsync(BASE_URL .. "/" .. BLOB_ID)
			local data = HttpService:JSONDecode(current)
			data[userId] = isOldUser
			HttpService:PutAsync(BASE_URL .. "/" .. BLOB_ID, {
				Headers = {["Content-Type"] = "application/json"},
				Body = HttpService:JSONEncode(data)
			})
		end)
		return success
	end
	
	local function loadData()
		local success, response = pcall(function()
			return HttpService:GetAsync(BASE_URL .. "/" .. BLOB_ID)
		end)
	
		if success then
			local data = HttpService:JSONDecode(response)
			return data[userId]
		end
		return nil
	end
	
	local isOldUser = loadData()
	
	if isOldUser == nil then
		saveData(false)
		print("New user")
	elseif isOldUser then
		print("Old user")
	else
		print("New user (has used before)")
	end
end;
